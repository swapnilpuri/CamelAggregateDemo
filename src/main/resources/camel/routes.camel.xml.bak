<?xml version="1.0" encoding="UTF-8"?>
<!--
  Banking ETL Pipeline — Apache Camel 4.x Spring XML DSL
  ========================================================
  6 routes:

  Route 1 (resumeCheck)        : startup timer → query ETL_PROGRESS for PENDING/FAILED
                                  → if found: re-send to seda:fetchPartition (resume mode)
                                  → if empty/table missing: call direct:partitionController
  Route 2 (partitionController): direct trigger → PartitionCalculator.calculatePartitions()
                                  → INSERT into ETL_PROGRESS (PENDING)
                                  → split List<RangePartition> → seda:fetchPartition
  Route 3 (fetchPartition)     : seda:fetchPartition(6) → mark IN_PROGRESS
                                  → SELECT * WHERE TRANSACTION_ID BETWEEN start AND end
                                  → split individual rows → seda:transformQueue
                                  → mark COMPLETED  |  on error: mark FAILED
  Route 4 (transformRecord)    : seda:transformQueue(8) → placeholder log
                                  → seda:insertQueue
  Route 5 (insertToKinetica)   : seda:insertQueue(6) → aggregate 10 000 rows
                                  → circuit breaker → kineticaBulkInsertProcessor
                                  → jdbc:kineticaDataSource
  Route 6 (manualTrigger)      : direct:triggerPipeline (UI "Run Pipeline" button)
                                  → clear ETL_PROGRESS → direct:partitionController

  ETL_PROGRESS states: PENDING → IN_PROGRESS → COMPLETED | FAILED
  Resilience4j circuit breaker on Route 5: failureRateThreshold=50%,
    waitDurationInOpenState=10s.
-->
<routes xmlns="http://camel.apache.org/schema/xml-dsl">

  <!-- ================================================================
       Route 1 — resumeCheck
       Fires once 1 s after startup. Queries ETL_PROGRESS for any
       PENDING or FAILED partitions left over from a prior run.
         • If found  → converts each row back to a RangePartition and
                       re-queues to seda:fetchPartition (resume mode).
         • If empty  → delegates to direct:partitionController for a
                       fresh run.
         • If table  → ORA-00942 (first ever start); catches the
           missing     exception and delegates to partitionController.
       ================================================================ -->
  <route id="resumeCheck" autoStartup="true">
    <from uri="timer:startupCheckTimer?repeatCount=1&amp;delay=1000" />

    <log message="[resumeCheck] Checking ETL_PROGRESS for resumable partitions…" loggingLevel="INFO" />

    <doTry>
      <setBody>
        <constant>
          SELECT PARTITION_ID, RANGE_START, RANGE_END
          FROM ETL_PROGRESS
          WHERE STATUS IN ('PENDING', 'FAILED')
          ORDER BY PARTITION_ID
        </constant>
      </setBody>
      <to uri="jdbc:oracleDataSource" />

      <!-- body is now List<Map<String,Object>> from JDBC -->
      <setHeader name="resumedCount">
        <simple resultType="java.lang.Integer">${body.size()}</simple>
      </setHeader>

      <choice>
        <when>
          <simple>${header.resumedCount} > 0</simple>
          <log
            message="[resumeCheck] Resuming ${header.resumedCount} partition(s) — dispatching to seda:fetchPartition"
            loggingLevel="INFO" />
          <split>
            <simple>${body}</simple>
            <!-- Convert Map row → RangePartition, then enqueue -->
            <bean ref="partitionCalculator" method="toRangePartition" />
            <to uri="seda:fetchPartition?concurrentConsumers=6&amp;size=500&amp;blockWhenFull=true" />
          </split>
        </when>
        <otherwise>
          <log message="[resumeCheck] No pending partitions — delegating to partitionController"
            loggingLevel="INFO" />
          <to uri="direct:partitionController" />
        </otherwise>
      </choice>

      <doCatch>
        <!-- ETL_PROGRESS doesn't exist yet on first-ever startup (ORA-00942) -->
        <exception>java.sql.SQLException</exception>
        <log
          message="[resumeCheck] ETL_PROGRESS not accessible (${exception.message}) — starting fresh"
          loggingLevel="INFO" />
        <to uri="direct:partitionController" />
      </doCatch>
    </doTry>
  </route>


  <!-- ================================================================
       Route 2 — partitionController
       Invoked via direct: (from resumeCheck or manualTrigger).
       Calls PartitionCalculator which:
         1. Queries MIN/MAX TRANSACTION_ID from BANK_TRANSACTIONS
         2. Divides the range into 100 000-row partitions
         3. Inserts PENDING tracking rows into ETL_PROGRESS
         4. Returns List<RangePartition>
       Each partition is then split and dispatched to seda:fetchPartition.
       ================================================================ -->
  <route id="partitionController">
    <from uri="direct:partitionController" />

    <log message="[partitionController] Calculating partitions over BANK_TRANSACTIONS…"
      loggingLevel="INFO" />

    <!-- Bean returns List<RangePartition>; also writes ETL_PROGRESS rows -->
    <bean ref="partitionCalculator" method="calculatePartitions" />

    <setHeader name="partitionCount">
      <simple resultType="java.lang.Integer">${body.size()}</simple>
    </setHeader>

    <choice>
      <when>
        <simple>${header.partitionCount} > 0</simple>
        <log
          message="[partitionController] Dispatching ${header.partitionCount} partition(s) to seda:fetchPartition"
          loggingLevel="INFO" />
        <split>
          <simple>${body}</simple>
          <to uri="seda:fetchPartition?concurrentConsumers=6&amp;size=500&amp;blockWhenFull=true" />
        </split>
        <log message="[partitionController] All partitions dispatched" loggingLevel="INFO" />
      </when>
      <otherwise>
        <log message="[partitionController] No partitions to process (BANK_TRANSACTIONS is empty?)"
          loggingLevel="WARN" />
      </otherwise>
    </choice>
  </route>


  <!-- ================================================================
       Route 3 — fetchPartition
       Consumes one RangePartition from seda:fetchPartition.
       6 concurrent consumers run independent range queries in parallel.

       Steps:
         1. Extract partitionId / startId / endId into headers
         2. Mark ETL_PROGRESS row IN_PROGRESS
         3. SELECT * FROM BANK_TRANSACTIONS WHERE TRANSACTION_ID BETWEEN …
            (StreamList keeps memory bounded)
         4. Split individual rows → seda:transformQueue
         5. Mark ETL_PROGRESS row COMPLETED
         On any exception: mark FAILED (doTry/doCatch — headers are
         captured before the try block so they're always available).
       ================================================================ -->
  <route id="fetchPartition">
    <from uri="seda:fetchPartition?concurrentConsumers=6&amp;size=500" />

    <!-- Capture partition metadata before body is replaced -->
    <setHeader name="partitionId">
      <simple>${body.partitionId}</simple>
    </setHeader>
    <setHeader name="startId">
      <simple>${body.startId}</simple>
    </setHeader>
    <setHeader name="endId">
      <simple>${body.endId}</simple>
    </setHeader>

    <doTry>

      <!-- Step 1: mark IN_PROGRESS -->
      <setBody>
        <simple>UPDATE ETL_PROGRESS SET STATUS = 'IN_PROGRESS', UPDATED_AT = SYSDATE WHERE
          PARTITION_ID = ${header.partitionId}</simple>
      </setBody>
      <to uri="jdbc:oracleDataSource" />

      <log
        message="[fetchPartition] Fetching partition ${header.partitionId}: IDs ${header.startId}–${header.endId}"
        loggingLevel="INFO" />

      <!-- Step 2: range SELECT (StreamList = lazy iterator, bounded heap) -->
      <setBody>
        <simple>SELECT * FROM BANK_TRANSACTIONS WHERE TRANSACTION_ID BETWEEN ${header.startId} AND
          ${header.endId} ORDER BY TRANSACTION_ID</simple>
      </setBody>
      <to uri="jdbc:oracleDataSource?outputType=StreamList" />

      <!-- Step 3: fan out individual rows to transformQueue -->
      <split streaming="true">
        <simple>${body}</simple>
        <to uri="seda:transformQueue?concurrentConsumers=8&amp;size=5000&amp;blockWhenFull=true" />
      </split>

      <!-- Step 4: mark COMPLETED (runs after all rows are enqueued) -->
      <setBody>
        <simple>UPDATE ETL_PROGRESS SET STATUS = 'COMPLETED', UPDATED_AT = SYSDATE WHERE
          PARTITION_ID = ${header.partitionId}</simple>
      </setBody>
      <to uri="jdbc:oracleDataSource" />

      <log message="[fetchPartition] Partition ${header.partitionId} COMPLETED" loggingLevel="INFO" />

      <doCatch>
        <exception>java.lang.Exception</exception>
        <log message="[fetchPartition] Partition ${header.partitionId} FAILED: ${exception.message}"
          loggingLevel="ERROR" />
        <setBody>
          <simple>UPDATE ETL_PROGRESS SET STATUS = 'FAILED', UPDATED_AT = SYSDATE WHERE PARTITION_ID
            = ${header.partitionId}</simple>
        </setBody>
        <to uri="jdbc:oracleDataSource" />
      </doCatch>

    </doTry>
  </route>


  <!-- ================================================================
       Route 4 — transformRecord  (UNCHANGED)
       Placeholder transformation step.
       8 concurrent consumers provide parallelism for CPU-bound work.
       ================================================================ -->
  <route id="transformRecord">
    <from uri="seda:transformQueue?concurrentConsumers=8&amp;size=5000" />

    <onException>
      <exception>java.sql.SQLException</exception>
      <exception>java.net.ConnectException</exception>
      <redeliveryPolicy
        maximumRedeliveries="3"
        redeliveryDelay="2000"
        logRetryAttempted="true"
        retryAttemptedLogLevel="WARN" />
      <handled>
        <constant>true</constant>
      </handled>
      <log
        message="[transformRecord][ERROR] ${exception.class.simpleName} after ${header.CamelRedeliveryCounter} retries: ${exception.message}"
        loggingLevel="ERROR" />
    </onException>

    <!-- TODO: replace this log with real transformation logic -->
    <log
      message="[transformRecord] Processing record: TRANSACTION_ID=${body[TRANSACTION_ID]}, AMOUNT=${body[AMOUNT]}, CURRENCY=${body[CURRENCY]}"
      loggingLevel="DEBUG" />

    <to uri="seda:insertQueue?concurrentConsumers=6&amp;size=5000&amp;blockWhenFull=true" />
  </route>


  <!-- ================================================================
       Route 5 — insertToKinetica  (GPUdb BulkInserter)
       Consumes individual row exchanges from seda:insertQueue.
       8 concurrent consumers share one BulkInserter<GenericRecord> bean
       which is thread-safe and batches records internally.

       KineticaInsertBean.insert(Map) converts the Oracle row to a
       GenericRecord and calls bulkInserter.insert().  BulkInserter
       flushes automatically when kinetica.batchSize records accumulate
       or every 5 s via its @Scheduled flush.

       The Resilience4j circuit breaker protects against Kinetica outages:
         • CLOSED (normal): insert() called, failure increments CB counter
         • OPEN  (≥50% fail rate in 10-call window): onFallback fires,
           record is dropped and logged
         • HALF_OPEN: 3 probe calls after 10 s quiet period
       ================================================================ -->
  <route id="insertToKinetica">
    <from uri="seda:insertQueue?concurrentConsumers=8&amp;size=5000" />

    <onException>
      <exception>java.lang.Exception</exception>
      <redeliveryPolicy
        maximumRedeliveries="3"
        redeliveryDelay="2000"
        logRetryAttempted="true"
        retryAttemptedLogLevel="WARN" />
      <handled>
        <constant>false</constant>
      </handled>
      <log message="[insertToKinetica][ERROR] ${exception.class.simpleName}: ${exception.message}"
        loggingLevel="ERROR" />
    </onException>

    <circuitBreaker>
      <resilience4jConfiguration
        circuitBreakerName="kineticaInsert"
        slidingWindowSize="10"
        failureRateThreshold="50"
        waitDurationInOpenState="10000"
        permittedNumberOfCallsInHalfOpenState="3"
        automaticTransitionFromOpenToHalfOpenEnabled="true" />

      <!-- Body is Map<String,Object> (one row from Oracle).
           KineticaInsertBean converts it to GenericRecord and queues it
           in the shared BulkInserter — no JDBC, no manual batching. -->
      <bean ref="kineticaInsertBean" method="insert" />

      <onFallback>
        <log
          message="[insertToKinetica] Circuit breaker OPEN — record ${body[TRANSACTION_ID]} dropped"
          loggingLevel="WARN" />
      </onFallback>
    </circuitBreaker>

  </route>


  <!-- ================================================================
       Route 6 — manualTrigger  (UI "Run Pipeline" button)
       Accepts a direct: call from MetricsController.startPipeline().
       Clears ETL_PROGRESS so partitionController starts a clean run,
       then delegates to direct:partitionController.
       ================================================================ -->
  <route id="manualTrigger">
    <from uri="direct:triggerPipeline" />

    <onException>
      <exception>java.sql.SQLException</exception>
      <exception>java.net.ConnectException</exception>
      <redeliveryPolicy maximumRedeliveries="3" redeliveryDelay="2000"
        logRetryAttempted="true" retryAttemptedLogLevel="WARN" />
      <handled>
        <constant>true</constant>
      </handled>
      <log message="[manualTrigger][ERROR] ${exception.class.simpleName}: ${exception.message}"
        loggingLevel="ERROR" />
    </onException>

    <log message="[manualTrigger] Pipeline triggered via UI" loggingLevel="INFO" />

    <!-- Reset ETL_PROGRESS so partitionController creates fresh partitions -->
    <doTry>
      <setBody>
        <constant>DELETE FROM ETL_PROGRESS</constant>
      </setBody>
      <to uri="jdbc:oracleDataSource" />
      <doCatch>
        <exception>java.sql.SQLException</exception>
        <log
          message="[manualTrigger] Could not clear ETL_PROGRESS (${exception.message}) — proceeding anyway"
          loggingLevel="WARN" />
      </doCatch>
    </doTry>

    <to uri="direct:partitionController" />

    <log message="[manualTrigger] Partitions dispatched" loggingLevel="INFO" />
  </route>

</routes>